# Steam data provider: steamapis (paid key, low free limit) or steam_official (free Web API key)
STEAM_PROVIDER=steamapis
# For STEAM_PROVIDER=steamapis: key from https://steamapis.com
STEAM_API_KEY=your_steam_api_key
# For STEAM_PROVIDER=steam_official: free key from https://steamcommunity.com/dev/apikey
STEAM_WEB_API_KEY=

# Telegram bot (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Watched inventory: Steam ID (64-bit) and App ID (730=CS2, 570=Dota2)
STEAM_ID=76561198000000000
APP_ID=730

# Notify when price changes by at least this percent (e.g. 50 = 50%)
THRESHOLD_PERCENT=50

# Poll interval in minutes
POLL_INTERVAL_MINUTES=10

# Optional: notify on price drop too (default: only on rise)
NOTIFY_ON_DROP=false

# Min price in USD to send notifications (skip cheaper items; 0 = no filter)
MIN_PRICE_USD=0.10
